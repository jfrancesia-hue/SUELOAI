# ============================================
# Suelo v4 - Variables de entorno
# ============================================

# ============================================
# SUPABASE (obligatorio)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# APP CONFIG
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Suelo
NEXT_PUBLIC_VERIFY_URL=http://localhost:3000/verify

# ============================================
# ANTHROPIC (Claude - scoring, analyst, fiscal, reports)
# Obtener en https://console.anthropic.com
# ============================================
ANTHROPIC_API_KEY=sk-ant-...

# Modelo default (override para ajustar costo/calidad)
#   claude-opus-4-7    → máxima inteligencia (scoring + análisis profundo)
#   claude-sonnet-4-6  → balance velocidad/calidad (chat default)
#   claude-haiku-4-5   → rápido y barato (onboarding, clasificación)
ANTHROPIC_MODEL_ANALYST=claude-sonnet-4-6
ANTHROPIC_MODEL_SCORING=claude-opus-4-7
ANTHROPIC_MODEL_FAST=claude-haiku-4-5

# ============================================
# MERCADO PAGO (wallet deposits fiat)
# ============================================
MP_ACCESS_TOKEN=APP_USR-...
MP_PUBLIC_KEY=APP_USR-...

# ============================================
# TWILIO (WhatsApp para CRM)
# ============================================
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=+14155238886

# ============================================
# RESEND (emails transaccionales)
# ============================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=no-reply@suelo.ai

# ============================================
# RATE LIMITING (Upstash Redis - opcional, fallback a memoria)
# Crear proyecto gratis en https://console.upstash.com
# ============================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================
# SENTRY (opcional - para observability en prod)
# ============================================
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ============================================
# KYC (Didit recomendado para LATAM)
# ============================================
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
# Secret para validar HMAC del webhook (settear en dashboard de Didit)
DIDIT_WEBHOOK_SECRET=

# ============================================
# AFIP (Argentina) / SIFEN (Paraguay)
# ============================================
AFIP_PRODUCTION=false
SIFEN_PRODUCTION=false

# ============================================
# CRYPTO INTEGRATION
# ============================================

# Maestro HD wallet - EVM chains (Polygon, Ethereum, BSC)
# Generar con: ethers.HDNodeWallet.createRandom().neuter().extendedKey
# IMPORTANTE: Solo xpub (clave pública). La xprv debe estar en HSM/vault.
CRYPTO_MASTER_XPUB_EVM=xpub...

# Maestro HD wallet - Tron (para producción, usar provider custodial: Bitso/Circle/Fireblocks)
CRYPTO_MASTER_XPUB_TRON=xpub...

# Bitso Business API (Paraguay/LATAM Tron custodial)
BITSO_API_KEY=
BITSO_API_SECRET=
BITSO_TRON_HOT_WALLET=TXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Circle API (USDC programmable wallets)
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# Block explorer API keys (verificar tx on-chain)
POLYGONSCAN_API_KEY=
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
TRONGRID_API_KEY=

# ============================================
# BLOCKCHAIN ANCHORING (Polygon)
# ============================================
POLYGON_RPC_URL=https://polygon-rpc.com
ANCHOR_CONTRACT_ADDRESS=0x...
ANCHOR_PRIVATE_KEY=0x...
# Mantener saldo en MATIC (~5 USD soportan ~1000 anchors)

# Webhook secret (validar notificaciones de Alchemy/TronGrid)
CRYPTO_WEBHOOK_SECRET=random-secure-string-here

# ============================================
# ALCHEMY (webhooks de transacciones EVM)
# ============================================
ALCHEMY_API_KEY=
ALCHEMY_WEBHOOK_SIGNING_KEY=

# ============================================
# ADMIN (notificaciones de retiros que requieren aprobación)
# ============================================
ADMIN_NOTIFY_EMAILS=admin@suelo.ai

# ============================================
# LOCALE DEFAULT
# ============================================
NEXT_PUBLIC_DEFAULT_COUNTRY=PY
NEXT_PUBLIC_DEFAULT_CURRENCY=USD
